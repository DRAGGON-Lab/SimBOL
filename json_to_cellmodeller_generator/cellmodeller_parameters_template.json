{
  "_comment": "Fill in this file and pass it alongside your SBOL JSON to the converter.",

  "simulation": {
    "max_cells": 10000,
    "jitter_z": false,
    "gamma": 100.0,
    "pickle_steps": 50,
    "random_seed": 12345
  },

  "cell_types": [
    {
      "display_name": "Strain A",
      "color": [1.0, 0.3, 0.3],
      "growth_rate": 1.0,
      "division_length": 3.0,
      "division_noise": 0.5,
      "initial_pos": [0.0, 0.0, 0.0],
      "initial_dir": [1.0, 0.0, 0.0]
    }
  ],

  "kinetics": {
    "_comment": "Default rates applied to all interactions unless overridden below.",
    "production_rate": 0.05,
    "max_production_rate": 0.2,
    "degradation_rate": 0.01,
    "hill_coefficient": 2.0,
    "activation_threshold": 0.5,
    "repression_threshold": 0.5
  },

  "signaling": {
    "enabled": false,
    "grid_size": 100,
    "boundary_condition": "fixed",
    "signals": [
      {
        "name": "signal_0",
        "diffusion_rate": 0.1,
        "degradation_rate": 0.01
      }
    ]
  },

  "sbol_mapping": {
    "_comment": "Optional overrides. Leave empty to use automatic inference.",
    "component_to_celltype": {},
    "signal_component_ids": [],
    "ignore_component_ids": []
  }
}
